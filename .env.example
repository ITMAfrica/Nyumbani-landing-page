# =============================================================================
# Nyumbani Landing Page — Environment Variables
# =============================================================================
# Copiez ce fichier en .env et remplacez les valeurs par vos propres cles.
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# ITM Send Email API
# ---------------------------------------------------------------------------
# URL de base du service mail central d'ITM Africa (sans slash final).
# Les routes (/api/contact, etc.) sont ajoutees automatiquement par le code.
#   Production : https://email.itmafrica.com
#   Local dev  : http://localhost:5001
NEXT_PUBLIC_MAIL_API=

# Cle d'authentification Bearer token pour l'API mail ITM.
MAIL_SERVICE_API_KEY=

# Adresse email qui recoit les notifications de leads et newsletters.
# Exemple : client@nyumbani-africa.com
MAIL_RECEIVER_EMAIL=client@nyumbani-africa.com
